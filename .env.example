APP_NAME=MacroLens API
APP_ENV=development
API_PREFIX=/api/v1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/macrolens

FRED_API_KEY=your_fred_api_key

EXPLANATION_PROVIDER=rules_based
EXPLANATION_FALLBACK_PROVIDER=rules_based
EXPLANATION_ALLOW_FALLBACK=true
EXPLANATION_MODEL=macro-template-v1

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_API_KEY=

GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_TIMEOUT_SECONDS=30
GEMINI_API_KEY=

NEWS_CONTEXT_PROVIDER=gdelt
NEWS_CONTEXT_WINDOW_DAYS=7
NEWS_CONTEXT_MAX_ARTICLES=5
NEWS_CONTEXT_LANGUAGE=English
ANOMALY_CLUSTER_WINDOW_DAYS=7
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2/doc
GDELT_MAX_ANOMALY_AGE_DAYS=3650

ANTHROPIC_API_KEY=
